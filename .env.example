# ===== Database =====
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ===== JWT =====
JWT_SECRET=your_jwt_secret_min_32_characters_long
JWT_EXPIRES_IN=1h

# ===== Blockchain =====
RPC_URL=https://sepolia.base.org
CONTRACT_WALLET_REGISTRY=0xYourWalletRegistryAddress
CONTRACT_CERT_REGISTRY=0xYourCertRegistryAddress
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_without_0x_prefix

# ===== Admin =====
ADMIN_WALLET_ADDRESS=0xYourAdminWalletAddress

# ===== Server =====
PORT=3000
NODE_ENV=development
